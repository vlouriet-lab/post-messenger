rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /attachments/{chatId}/{fileName} {
      allow read: if request.auth != null && request.auth.uid in resource.metadata.participants.split(',');
      allow write: if request.auth != null && request.resource.size < 50 * 1024 * 1024
                   && request.auth.uid in request.resource.metadata.participants.split(',');
    }
  }
}
